# ============ Application ============
APP_NAME=bx-caller
APP_ENV=development

# Set to 1 ONLY in local development. Treats every request as one deterministic
# test user. Refused at startup if APP_ENV=production.
DEV_BYPASS_AUTH=0

# Must equal bixingai-tools apps/api JWT_SECRET exactly.
# Generate in the portal with: python -c "import secrets; print(secrets.token_urlsafe(48))"
PORTAL_JWT_SECRET=
PORTAL_JWT_ALGORITHM=HS256

# Optional shared token for telephony/WebSocket callbacks that cannot carry the
# portal browser cookie. Leave empty to require cookie auth on WebSockets.
WEBSOCKET_ACCESS_TOKEN=
TELEPHONY_PROVIDER=twilio
PUBLIC_BASE_URL=

# ============ Redis ============
# Docker default:
REDIS_URL=redis://redis:6379/0
# Local fallback when Docker/Redis is unavailable:
# REDIS_URL=memory://local

# ============ CORS ============
# Empty list is recommended when nginx mounts this same-origin under /bx-caller.
CORS_ORIGINS=[]

# ============ Provider keys ============
# Fill only the providers used by your agent configs.
OPENAI_API_KEY=
DEEPGRAM_AUTH_TOKEN=
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
