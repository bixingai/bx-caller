# Template for .env.prod on the server at /opt/bx-caller/.env.prod.
# NEVER commit a real .env.prod.

APP_NAME=bx-caller
APP_ENV=production
DEV_BYPASS_AUTH=0

# REQUIRED. Must equal bixingai-tools portal JWT_SECRET exactly.
PORTAL_JWT_SECRET=
PORTAL_JWT_ALGORITHM=HS256

# Optional. If external telephony callbacks need to reach /bx-caller/chat/v1/*,
# set a strong random value and append ?token=<value> to callback URLs.
WEBSOCKET_ACCESS_TOKEN=
TELEPHONY_PROVIDER=twilio
PUBLIC_BASE_URL=https://tools.bixingai.com/bx-caller

REDIS_URL=redis://redis:6379/0

# Registry prefix and namespace for image pulls. Tencent Cloud deployments can
# set REGISTRY=ccr.ccs.tencentyun.com and IMAGE_NAMESPACE=<your-namespace>.
REGISTRY=docker.io
IMAGE_NAMESPACE=pmtmyaggy

# Same-origin through tools.bixingai.com; keep empty unless debugging direct API access.
CORS_ORIGINS=[]

# Provider keys used by deployed agents.
OPENAI_API_KEY=
DEEPGRAM_AUTH_TOKEN=
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
